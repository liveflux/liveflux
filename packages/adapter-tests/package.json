{
  "name": "@liveflux/adapter-tests",
  "version": "0.1.0",
  "description": "Testing moat for Liveflux — a programmable MockAdapter plus a shared, protocol-agnostic conformance suite every StreamAdapter must pass.",
  "keywords": [
    "testing",
    "conformance",
    "adapter",
    "mock",
    "liveflux",
    "vitest"
  ],
  "license": "MIT",
  "author": {
    "name": "Bhavin Devamorari",
    "url": "https://bpdm.dev"
  },
  "homepage": "https://liveflux.bpdm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liveflux/liveflux.git",
    "directory": "packages/adapter-tests"
  },
  "bugs": "https://github.com/liveflux/liveflux/issues",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit",
    "format": "prettier --write src"
  },
  "peerDependencies": {
    "@liveflux/core": "workspace:*",
    "vitest": ">=2"
  },
  "devDependencies": {
    "@liveflux/core": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
