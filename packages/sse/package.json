{
  "name": "@liveflux/sse",
  "version": "0.1.0",
  "description": "Server-Sent Events (SSE) adapter for Liveflux — an EventSource stream with reconnect and cursor resume, for any backend in any language.",
  "keywords": [
    "sse",
    "server-sent-events",
    "eventsource",
    "realtime",
    "adapter",
    "liveflux",
    "reconnect",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "Bhavin Devamorari",
    "url": "https://bpdm.dev"
  },
  "homepage": "https://liveflux.bpdm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liveflux/liveflux.git",
    "directory": "packages/sse"
  },
  "bugs": "https://github.com/liveflux/liveflux/issues",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit",
    "format": "prettier --write src"
  },
  "peerDependencies": {
    "@liveflux/core": "workspace:*"
  },
  "devDependencies": {
    "@liveflux/adapter-tests": "workspace:*",
    "@liveflux/core": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
