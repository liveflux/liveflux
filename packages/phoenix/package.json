{
  "name": "@liveflux/phoenix",
  "version": "0.1.0",
  "description": "Phoenix Channels adapter for Liveflux — the Elixir Phoenix Channels v2 wire protocol, hand-rolled with zero runtime dependencies.",
  "keywords": [
    "phoenix",
    "phoenix-channels",
    "elixir",
    "realtime",
    "websocket",
    "liveflux"
  ],
  "license": "MIT",
  "author": {
    "name": "Bhavin Devamorari",
    "url": "https://bpdm.dev"
  },
  "homepage": "https://liveflux.bpdm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liveflux/liveflux.git",
    "directory": "packages/phoenix"
  },
  "bugs": "https://github.com/liveflux/liveflux/issues",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit",
    "format": "prettier --write src"
  },
  "peerDependencies": {
    "@liveflux/core": "workspace:*"
  },
  "devDependencies": {
    "@liveflux/adapter-tests": "workspace:*",
    "@liveflux/core": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
