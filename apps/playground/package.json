{
  "name": "playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local dev harness — NOT published. Runs every @liveflux/* package live in the browser.",
  "scripts": {
    "dev": "concurrently -n server,web -c magenta,cyan \"node server.mjs\" \"vite\"",
    "web": "vite",
    "mock": "node server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@liveflux/core": "workspace:*",
    "@liveflux/react": "workspace:*",
    "@liveflux/ws": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.0",
    "ws": "^8.18.0"
  }
}
